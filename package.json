{
  "name": "signalk-dead-mans-switch",
  "version": "0.5.0",
  "description": "The dead man's switch requires you to push a button, and escalates notifications from alert all the way up to emergency if you don't",
  "main": "index.js",
  "scripts": {
    "start": "node index.js",
    "test": "node --test --test-force-exit"
  },
  "keywords": [
    "signalk-node-server-plugin",
    "signalk-webapp",
    "signalk-category-safety"
  ],
  "signalk-plugin-enabled-by-default": false,
  "signalk": {
    "displayName": "Dead Man's Switch",
    "appIcon": "./assets/icons/icon-512.png",
    "screenshots": [
      "./docs/screenshots/armed.png",
      "./docs/screenshots/armed-dark.png",
      "./docs/screenshots/warn.png",
      "./docs/screenshots/emergency.png"
    ]
  },
  "author": "Tobias Rosenstock (humppafreak)",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/BoatHacks/signalk-dead-mans-switch.git"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "devDependencies": {
    "jsdom": "^29.1.1"
  }
}
